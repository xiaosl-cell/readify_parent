# Service / Nacos
SERVICE_NAME=readify-agi
SERVICE_PORT=8081

NACOS_ENABLED=true
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=ca5b6af9-5336-42f7-b68c-515779f79a98
NACOS_GROUP=READIFY
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos2025
NACOS_CLUSTER=DEFAULT
NACOS_HEARTBEAT_INTERVAL=5
NACOS_CONFIG_DATA_ID=readify-agi.yaml
READIFY_SERVER_SERVICE_NAME=readify-server

# Query Rewrite
QUERY_REWRITE_ENABLED=true

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai
# LLM_API_BASE examples:
#   OpenAI-compatible: https://api.openai.com/v1
#   Anthropic:         https://api.anthropic.com
#   Proxy example:     https://example.com/proxy/v1
# LLM_DEFAULT_HEADERS={"User-Agent": "Mozilla/5.0 ..."}

# Parser / OCR
PARSER_PROVIDER=local
OCR_BASE_URL=http://localhost:8090
OCR_LANG=ch
OCR_TIMEOUT_SEC=120
# Tencent OCR credentials when PARSER_PROVIDER=tencent
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou

# Embedding (Tencent Hunyuan OpenAI-compatible endpoint)
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://api.hunyuan.cloud.tencent.com/v1
EMBEDDING_MODEL=hunyuan-embedding
EMBEDDING_REQUEST_BATCH_SIZE=50
# Set a new collection name if you need to isolate old vectors before re-vectorizing
# EMBEDDING_COLLECTION_NAME=rf_documents_hunyuan
