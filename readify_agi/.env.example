# Service / Nacos
SERVICE_NAME=readify-agi
SERVICE_PORT=8081

NACOS_ENABLED=true
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=ca5b6af9-5336-42f7-b68c-515779f79a98
NACOS_GROUP=READIFY
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos2025
NACOS_CLUSTER=DEFAULT
NACOS_HEARTBEAT_INTERVAL=5
NACOS_CONFIG_DATA_ID=readify-agi.yaml
READIFY_SERVER_SERVICE_NAME=readify-server

# Query Rewrite
QUERY_REWRITE_ENABLED=true

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai
# LLM_API_BASE 配置说明:
#   OpenAI 格式:    https://api.openai.com/v1          （包含 /v1）
#   Anthropic 格式: https://api.anthropic.com           （不含 /v1，SDK 自动追加 /v1/messages）
#   反向代理示例:    https://example.com/proxy/v1        （程序会自动移除多余的 /v1 后缀）
# 自定义 HTTP 请求头（JSON 格式），用于绕过 WAF 拦截等场景，留空则不设置
# LLM_DEFAULT_HEADERS={"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}

# Agent 执行模式: "tool_calling" (原生函数调用，推荐) 或 "react" (文本ReAct格式)
# tool_calling 使用模型原生 Function Calling API，对指令遵循能力较弱的模型更鲁棒
# react 使用文本格式 Thought/Action/Observation，对模型的指令遵循要求更高
AGENT_MODE=tool_calling

# Parser / OCR
PARSER_PROVIDER=local
OCR_BASE_URL=http://localhost:8090
OCR_LANG=ch
OCR_TIMEOUT_SEC=120
